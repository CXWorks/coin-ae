    }
}

impl<EntryData> DoubleEndedIterator for IntoIter<EntryData> {
    fn next_back(&mut self) -> Option<Self::Item> {
        if self.remaining == 0 {
            None
        } else {
            self.tail.map(|index| {
                let entry = self
                    .list
                    .remove_entry(index)
                    .expect("expected occupied entry");
                self.tail = entry.previous;
                self.remaining -= 1;
