                }
                $(#[target_feature(enable = $target)])?
                unsafe fn fft_09<const FWD: bool>(x: *mut c64, y: *mut c64, w: *const c64) {
                    end_8::<$xn>(FWD, 1 << 3, 1 << 6, x, y, false);
                    core_::<$xn>(FWD, 1 << 6, 1 << 3, y, x, w);
