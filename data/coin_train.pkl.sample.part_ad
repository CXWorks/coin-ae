    let s = "J├żger,Ja╠łger,Õż¦Õ½īŃüä,­¤Æ¬ŌØż!";
    let r = (0..s.len()+1).map(|i| (i, StrCursor::new_at_right_of_byte_pos(s, i)))
        .map(|(i, cur)| (i, cur.byte_pos(), cur.after().map(Gc::as_str)))
        .collect::<Vec<_>>();
