                }
                $(#[target_feature(enable = $target)])?
                unsafe fn fft_15<const FWD: bool>(x: *mut c64, y: *mut c64, w: *const c64) {
                    end_8::<$xn>(FWD, 1 << 03, 1 << 12, x, y, false);
                    core_::<$xn>(FWD, 1 << 06, 1 << 09, y, x, w);
