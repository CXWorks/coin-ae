pub use opengauss_bindgen_macros::opengauss_bindgen;

static OPENGAUSS_TEXT: u8 = 3;
static OPENGAUSS_BLOB: u8 = 4;
static OPENGAUSS_NULL: u8 = 5;

// Type translation from Wasm pointers to strings, blobs and nulls
pub trait FromOpenGauss {
    fn from_opengauss_type(wasm_ptr: i32) -> Self;
}

// Type translation from strings, blobs and nulls to Wasm pointers
pub trait IntoOpenGauss {
    fn into_opengauss_type(self) -> i32;
}

impl FromOpenGauss for &str {
    fn from_opengauss_type(wasm_ptr: i32) -> Self {
        let raw_ptr = wasm_ptr as *const c_char;
        unsafe {
            if *raw_ptr != OPENGAUSS_TEXT as c_char {
                "???"
            } else {
                match CStr::from_ptr(raw_ptr.offset(1)).to_str() {
                    Ok(s) => s,
                    Err(_) => "!!!",
                }
            }
        }
    }
}

impl IntoOpenGauss for &str {
    fn into_opengauss_type(self) -> i32 {
        let mut mem: Vec<u8> = vec![0; self.len() + 2];
        mem[0] = OPENGAUSS_TEXT;
        mem[1..=self.len()].copy_from_slice(self.as_bytes());
        mem[self.len() + 1] = 0;
        let ptr = mem.as_ptr() as i32;
        std::mem::forget(mem);
        ptr
    }
}

impl FromOpenGauss for String {
    fn from_opengauss_type(wasm_ptr: i32) -> Self {
        <&str>::from_opengauss_type(wasm_ptr).to_owned()
    }
}

impl IntoOpenGauss for String {
    fn into_opengauss_type(self) -> i32 {
        self.as_str().into_opengauss_type()
    }
}

impl FromOpenGauss for &mut [u8] {
    fn from_opengauss_type(wasm_ptr: i32) -> Self {
        let raw_ptr = wasm_ptr as *const c_void;
        if unsafe { *(raw_ptr as *const c_char) != OPENGAUSS_BLOB as c_char } {
            &mut []
        } else {
            let size = unsafe {
                u32::from_be_bytes(
                    core::slice::from_raw_parts(raw_ptr.offset(1) as *const u8, 4)
                        .try_into()
                        .unwrap_or([0_u8, 0_u8, 0_u8, 0_u8]),
                )
            };
            unsafe { core::slice::from_raw_parts_mut(raw_ptr.offset(5) as *mut u8, size as usize) }
        }
    }
}

impl IntoOpenGauss for Vec<u8> {
    fn into_opengauss_type(self) -> i32 {
        let mut mem: Vec<u8> = vec![0; self.len() + 5];
        mem[0] = OPENGAUSS_BLOB;
        mem[1..5].copy_from_slice(&u32::to_be_bytes(self.len() as u32));
        mem[5..].copy_from_slice(&self);
        let ptr = mem.as_ptr() as i32;
        std::mem::forget(mem);
        ptr
    }
}

impl<T: FromOpenGauss> FromOpenGauss for Option<T> {
    fn from_opengauss_type(wasm_ptr: i32) -> Self {
        let raw_ptr = wasm_ptr as *const c_char;
        unsafe {
            if *raw_ptr == OPENGAUSS_NULL as c_char {
                None
            } else {
                Some(<T>::from_opengauss_type(wasm_ptr))
            }
        }
    }
}

#[no_mangle]
pub unsafe extern "C" fn opengauss_malloc(size: usize) -> usize {
    let buffer = Vec::<u8>::with_capacity(size);
    let ptr = Vec::leak(buffer);
    ptr.as_ptr() as usize
}
