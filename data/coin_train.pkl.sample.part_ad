    0x3F => EXTCODEHASH    => host::extcodehash::<H, SPEC>      => stack_io<1, 1>, not_eof;
    0x40 => BLOCKHASH      => host::blockhash                   => stack_io<1, 1>;
    0x41 => COINBASE       => host_env::coinbase                => stack_io<0, 1>;
