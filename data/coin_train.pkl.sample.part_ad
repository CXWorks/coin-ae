                }
                $(#[target_feature(enable = $target)])?
                unsafe fn fft_12<const FWD: bool>(x: *mut c64, y: *mut c64, w: *const c64) {
                    end_8::<$xn>(FWD, 1 << 03, 1 << 09, y, x, true);
                    core_::<$xn>(FWD, 1 << 06, 1 << 06, x, y, w);
