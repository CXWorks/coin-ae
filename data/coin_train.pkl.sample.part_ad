#[cfg_attr(feature = "serialize", derive(Serialize))]
#[cfg_attr(feature = "deserialize", derive(Deserialize))]
#[derive(Debug, Clone, PartialEq, Trace)]
#[trivially_drop]
pub struct BindSpec {
	pub name: IStr,
	pub params: Option<ParamsDesc>,
