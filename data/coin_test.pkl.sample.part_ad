#[derive(Copy, Clone, Eq, PartialEq, Ord, PartialOrd, Hash)]
pub struct Name {
    index: i32,
}

impl Name {
    pub(crate) const unsafe fn new(index: i32) -> Self {
        Name { index }
    }

