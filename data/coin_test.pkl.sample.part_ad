    /// // cosh(1.25) = 1.8884, using 4 significant bits: 1.875
    /// let (dir_sinh, dir_cosh) =
    ///     sinh.sinh_cosh_round(&mut cosh, Round::Nearest);
    /// assert_eq!(sinh, 1.625);
