    ///   * <code>[Assign]\<Src> for [(][tuple]\&mut [Float], \&mut [Float][][)][tuple]</code>
    ///   * <code>[AssignRound]\<Src> for [(][tuple][Float][], [Float][][)][tuple]</code>
    ///   * <code>[AssignRound]\<Src> for [(][tuple]\&mut [Float], \&mut [Float][][)][tuple]</code>
