    /// ÕÉŹÕēŹŃéÆµīćÕ«ÜŃüŚŃü”Ńā”ŃāŗŃāĢŃé®Ńā╝ŃāĀÕżēµĢ░ŃéÆĶ┐ĮÕŖĀŃüÖŃéŗ
    pub fn add(&mut self, name: &'a CStr, value: Uniform<'a>) -> &mut Self {
        self.map.insert(name, value);
