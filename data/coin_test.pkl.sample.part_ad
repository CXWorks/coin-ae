    /// glDeleteShaderŃüĢŃéīŃü”ŃüäŃü¬ŃüäķÖÉŃéŖÕ«ēÕģ©
    pub unsafe fn raw_id(&self) -> GLuint {
        self.id
    }
}

impl Drop for Shader {
    /// OpenGLŃüīõ┐ØµīüŃüŚŃü”ŃüäŃéŗŃéĘŃé¦Ńā╝ŃāĆŃā╝Ńü«Õ«¤õĮōŃééÕēŖķÖżŃüĢŃéīŃéŗ(glDeleteProgram)
